{
    "name": "firevel/sortable",
    "description": "A simple trait to make your Laravel Eloquent models sortable with ease.",
    "keywords": ["laravel", "firevel", "trait", "sortable"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Michael Slowik",
            "email": "michael.slowik@firevel.com"
        }
    ],
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0",
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Firevel\\Sortable\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Firevel\\Sortable\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Firevel\\Sortable\\SortableServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}